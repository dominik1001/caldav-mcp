# CalDAV Server Configuration
CALDAV_BASE_URL=https://your-caldav-server.com/dav
CALDAV_USERNAME=your-username
CALDAV_PASSWORD=your-password

# Optional: HTTP transport (--http) settings
# PORT=3000
# LISTEN_ADDR=localhost
# Bearer token required on POST /mcp when set; unset = unauthenticated endpoint.
# MCP_API_KEY=your-shared-secret

# Note: Copy this file to .env and fill in your actual credentials
# Always use HTTPS for CALDAV_BASE_URL
